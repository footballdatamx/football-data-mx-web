---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("articulos");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} — Football Data MX`}>
  <article class="wrap" style="padding: 4rem 1.5rem; max-width: 68ch;">
    <p class="eyebrow" style="font-family: var(--font-mono); color: var(--color-pitch);">
      {post.data.date.toLocaleDateString("es-MX", { year: "numeric", month: "long", day: "numeric" })}
    </p>
    <h1 style="font-size: 2.2rem; margin: 0.5rem 0 2rem;">{post.data.title}</h1>
    <div class="post-body">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .post-body {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.75;
  }
  .post-body :global(p) {
    margin: 0 0 1.25rem;
  }
</style>
