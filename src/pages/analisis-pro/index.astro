---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("analisisPro")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// Piezas de análisis interactivo (con gráficas), no viven en la colección de Markdown
const analisisInteractivos = [
  {
    href: "/analisis-pro/penales-mundialistas",
    title: "Penales de Mundial: lo que 320 tiros nos dicen sobre a dónde patear",
    fecha: "2026",
  },
];
---

<Layout title="Análisis Pro — Football Data MX">
  <section class="lineup wrap">
    <h2>Análisis Pro</h2>
    {
      analisisInteractivos.map((a) => (
        <a class="lineup-row" href={a.href}>
          <span class="lineup-title">{a.title}</span>
          <span class="lineup-cadence">{a.fecha}</span>
        </a>
      ))
    }
    {
      posts.length === 0 && analisisInteractivos.length === 0 && (
        <p style="font-family: var(--font-mono); color: var(--color-mist); padding: 2rem 0;">
          Aún no hay análisis publicados. Esta sección arranca cuando el ritmo de Blog y
          Amateur esté estable (Fase 2 del plan), con cadencia mensual y foco en ligas
          europeas por disponibilidad de datos abiertos.
        </p>
      )
    }
    {
      posts.map((post) => (
        <a class="lineup-row" href={`/analisis-pro/${post.id}`}>
          <span class="lineup-title">{post.data.title}</span>
          <span class="lineup-cadence">
            {post.data.date.toLocaleDateString("es-MX", {
              year: "numeric",
              month: "short",
              day: "numeric",
            })}
          </span>
        </a>
      ))
    }
  </section>
</Layout>

